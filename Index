        { text: "Which of the following is an example of an aromatic hydrocarbon?", options: ["Methane", "Ethene", "Benzene", "Butane"], correct: 2, explanation: "Benzene has delocalized π electrons." },
        { text: "Which of the following is a trihydroxy alcohol?", options: ["Glycerol", "Methanol", "Ethanol", "Propanol"], correct: 0, explanation: "Glycerol (propane-1,2,3-triol)." },
