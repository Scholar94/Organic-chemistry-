        { text: "Which element is commonly found in proteins but not in carbohydrates?", options: ["Carbon", "Hydrogen", "Nitrogen", "Oxygen"], correct: 2, explanation: "Proteins contain nitrogen from amino groups." },
        { text: "Which of the following molecules has the empirical formula CH₂O?", options: ["Glucose", "Sucrose", "Ribose", "Fructose"], correct: 0, explanation: "C₆H₁₂O₆ simplifies to CH₂O." },
