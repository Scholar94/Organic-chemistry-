        { text: "What is the IUPAC name of CH₃CH₂COOH?", options: ["Ethanoic acid", "Methanoic acid", "Propanoic acid", "Butanoic acid"], correct: 2, explanation: "Propanoic acid (3-carbon chain)." },
        { text: "Which reagent is used to test for proteins?", options: ["Benedict’s solution", "Biuret reagent", "Bromine water", "Limewater"], correct: 1, explanation: "Biuret test detects peptide bonds." },
        { text: "A compound that contains both –COOH and –NH₂ groups is:", options: ["Fatty acid", "Amino acid", "Glucose", "Ester"], correct: 1, explanation: "Amino acids have both amino and carboxyl groups." },
        { text: "Which of the following organic compounds is used in perfumes and flavorings?", options: ["Esters", "Alkanes", "Ketones", "Proteins"], correct: 0, explanation: "Esters provide fragrance." },
        { text: "Which of the following carbohydrates is stored in the liver?", options: ["Cellulose", "Glycogen", "Glucose", "Fructose"], correct: 1, explanation: "Glycogen is animal storage polysaccharide." },
        { text: "Which of the following can be used to distinguish between aldehydes and ketones?", options: ["Bromine water", "Benedict’s solution", "Tollen’s reagent", "Sodium carbonate"], correct: 2, explanation: "Tollen’s reagent oxidizes aldehydes (silver mirror), not ketones." },
        { text: "Which of the following statements is true about alkynes?", options: ["They are saturated hydrocarbons", "They contain a double bond", "They are more reactive than alkanes", "They do not undergo addition reactions"], correct: 2, explanation: "Alkynes (triple bond) are reactive and undergo addition." },
        { text: "What is the name of the compound CH₃CH₂CH=CH₂?", options: ["Butane", "Butene", "Butyne", "Propene"], correct: 1, explanation: "But-1-ene (terminal alkene)." },
        { text: "Which of the following substances is most likely to be a wax?", options: ["Protein", "Lipid", "Carbohydrate", "Amino acid"], correct: 1, explanation: "Waxes are esters of long-chain fatty acids and alcohols." },
        { text: "What is the product of the reaction between ethanol and ethanoic acid?", options: ["Ethyl ethanoate", "Acetic alcohol", "Acetone", "Ethanal"], correct: 0, explanation: "Esterification gives ethyl ethanoate (ethyl acetate)." },
        { text: "What kind of bond holds the double helix of DNA together?", options: ["Ionic bonds", "Peptide bonds", "Hydrogen bonds", "Metallic bonds"], correct: 2, explanation: "Hydrogen bonds between base pairs." },
        { text: "Which class of compound is represented by the general formula CnH2n+1OH?", options: ["Carboxylic acids", "Aldehydes", "Alcohols", "Ketones"], correct: 2, explanation: "Saturated alcohols." },
        { text: "What type of compound is CH₃COOCH₃?", options: ["Ketone", "Ester", "Ether", "Alcohol"], correct: 1, explanation: "Methyl ethanoate (ester)." },
        { text: "What is the main storage form of carbohydrate in plants?", options: ["Starch", "Glycogen", "Cellulose", "Glucose"], correct: 0, explanation: "Starch stores energy in plants." },
        { text: "Which compound has a fruity smell and is commonly found in pineapple flavor?", options: ["Methyl ethanoate", "Ethyl butanoate", "Propanoic acid", "Ethanol"], correct: 1, explanation: "Ethyl butanoate has pineapple odor." },
        { text: "The chemical test used to identify starch is:", options: ["Benedict’s test", "Iodine test", "Biuret test", "Molisch’s test"], correct: 1, explanation: "Iodine gives blue-black color with starch." },
        { text: "What are the monomers of proteins?", options: ["Monosaccharides", "Fatty acids", "Amino acids", "Nucleotides"], correct: 2, explanation: "Amino acids are building blocks." },
        { text: "The simplest alkyne is:", options: ["Ethene", "Methyne", "Ethyne", "Propyne"], correct: 2, explanation: "Ethyne (C₂H₂) is the first alkyne." },
        { text: "What is the product of the complete combustion of a hydrocarbon?", options: ["CO and H₂O", "CO₂ and H₂O", "CO₂ and H₂", "H₂ and O₂"], correct: 1, explanation: "Complete combustion yields CO₂ + H₂O." },
        { text: "Which of the following organic compounds contains a –C≡C– bond?", options: ["Alkanes", "Alkenes", "Alkynes", "Aromatic hydrocarbons"], correct: 2, explanation: "Alkynes feature a carbon-carbon triple bond." },
        { text: "Which functional group is present in sugars?", options: ["Carboxylic", "Aldehyde or ketone", "Ester", "Amide"], correct: 1, explanation: "Sugars contain carbonyl (aldehyde/ketone) and hydroxyl." },
        { text: "What is the test used for lipids?", options: ["Iodine test", "Sudan III stain test", "Biuret test", "Benedict’s test"], correct: 1, explanation: "Sudan III stains lipids red/orange." },
        { text: "What is the general formula for alkynes?", options: ["CnH2n", "CnH2n–2", "CnH2n+2", "CnH2n+1"], correct: 1, explanation: "Alkynes: CnH2n-2." },
        { text: "The hydrogenation of vegetable oils is an example of:", options: ["Addition reaction", "Condensation reaction", "Polymerization", "Substitution reaction"], correct: 0, explanation: "Addition of H₂ across double bonds." },
        { text: "The compound with formula C₆H₆ is:", options: ["Cyclohexane", "Benzene", "Hexanol", "Phenol"], correct: 1, explanation: "Benzene (aromatic)." },
        { text: "Which of the following organic compounds is used in the manufacture of soap?", options: ["Esters", "Alcohols", "Carboxylic acids", "Fats and oils"], correct: 3, explanation: "Fats and oils undergo saponification." },
        { text: "What is the IUPAC name for CH₃CH₂COOCH₃?", options: ["Methyl propanoate", "Propyl methanoate", "Ethyl acetate", "Methyl acetate"], correct: 0, explanation: "Methyl propanoate from propanoic acid and methanol." },
        { text: "What is the function of enzymes in organic reactions in living cells?", options: ["Increase pH", "Provide energy", "Act as biological catalysts", "Decrease solubility"], correct: 2, explanation: "Enzymes speed up reactions without being consumed." }
    ];
    // Ensure exactly 100 questions (the array already contains 100)
    console.assert(FULL_QUESTION_SET.length === 100, "Questions length: " + FULL_QUESTION_SET.length);
    
    // ----- Helper functions -----
    function shuffleArray(arr) {
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }
    
    // App state
    let currentQuestions = [];          // shuffled question objects with shuffled options
    let studentAnswers = new Array(100).fill(null); // stores selected option index per question
    let currentIndex = 0;
    let quizActive = false;
    let studentData = { name: "", class: "", school: "", date: "", id: "" };
    
    // DOM elements
    const studentSection = document.getElementById('studentInfoSection');
    const welcomeBarDiv = document.getElementById('welcomeBar');
    const quizPanelDiv = document.getElementById('quizPanel');
    const resultPanelDiv = document.getElementById('resultPanel');
    const startQuizBtn = document.getElementById('startQuizBtn');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const submitQuizBtn = document.getElementById('submitQuizBtn');
    const restartBarBtn = document.getElementById('restartFromBarBtn');
    const restartResultBtn = document.getElementById('restartResultBtn');
    const downloadBtn = document.getElementById('downloadPdfBtn');
    
    function updateProgressBar() {
        const percent = ((currentIndex + 1) / 100) * 100;
        document.getElementById('progressFill').style.width = `${percent}%`;
    }
    
    function renderQuestion() {
        if (!quizActive) return;
        const q = currentQuestions[currentIndex];
        document.getElementById('questionText').innerHTML = q.text;
        const container = document.getElementById('optionsContainer');
        container.innerHTML = '';
        q.options.forEach((opt, idx) => {
            const li = document.createElement('li');
            li.className = 'option-item';
            if (studentAnswers[currentIndex] === idx) li.classList.add('selected');
            li.innerHTML = `${String.fromCharCode(65+idx)}. ${opt}`;
            li.addEventListener('click', () => {
                if (quizActive) {
                    studentAnswers[currentIndex] = idx;
                    renderQuestion();
                }
            });
            container.appendChild(li);
        });
        document.getElementById('questionCounter').innerText = `Q${currentIndex+1} / 100`;
        updateProgressBar();
    }
    
    function initQuiz() {
        quizActive = true;
        currentIndex = 0;
        studentAnswers.fill(null);
        // Shuffle questions and also shuffle options per question for randomization
        let shuffledQuestions = shuffleArray([...FULL_QUESTION_SET]);
        shuffledQuestions = shuffledQuestions.map(q => {
            const optsCopy = [...q.options];
            const correctAnswerText = q.options[q.correct];
            const shuffledOpts = shuffleArray([...optsCopy]);
            const newCorrectIdx = shuffledOpts.indexOf(correctAnswerText);
            return { text: q.text, options: shuffledOpts, correct: newCorrectIdx, explanation: q.explanation };
        });
        currentQuestions = shuffledQuestions;
        renderQuestion();
    }
    
    function showQuizInterface() {
        studentSection.style.display = 'none';
        welcomeBarDiv.style.display = 'flex';
        quizPanelDiv.style.display = 'block';
        resultPanelDiv.style.display = 'none';
        document.getElementById('welcomeMsg').innerHTML = `🎓 Welcome, ${studentData.name}! 🧪`;
        initQuiz();
    }
    
    function computeAndShowResult() {
        let correctCount = 0;
        for (let i = 0; i < 100; i++) {
            if (studentAnswers[i] !== null && studentAnswers[i] === currentQuestions[i].correct) correctCount++;
        }
        const wrongCount = 100 - correctCount;
        const resultHtml = `<div class="result-summary">
            <h3>📘 Student Details</h3>
            <p><strong>Name:</strong> ${studentData.name} &nbsp;| <strong>Class:</strong> ${studentData.class} &nbsp;| <strong>School:</strong> ${studentData.school}<br>
            <strong>Date:</strong> ${studentData.date} &nbsp;| <strong>Student ID:</strong> ${studentData.id || 'Not provided'}</p>
            <h2>🏆 Score: ${correctCount}/100 (${correctCount} correct, ${wrongCount} wrong)</h2>
            </div>`;
        document.getElementById('resultDetails').innerHTML = resultHtml;
        let reviewHtml = '';
        for (let i = 0; i < currentQuestions.length; i++) {
            const q = currentQuestions[i];
            const userChoice = studentAnswers[i];
            const isCorrect = (userChoice !== null && userChoice === q.correct);
            const correctLetter = String.fromCharCode(65 + q.correct);
            const correctAns = q.options[q.correct];
            const userLetter = (userChoice !== null) ? String.fromCharCode(65 + userChoice) : '—';
            const userAnsText = (userChoice !== null) ? q.options[userChoice] : 'No answer';
            reviewHtml += `<div class="review-item ${!isCorrect ? 'review-wrong' : ''}">
                <strong>Q${i+1}: ${q.text}</strong><br>
                <div>📌 Options: ${q.options.map((opt,idx)=>`${String.fromCharCode(65+idx)}. ${opt}`).join(' | ')}</div>
                <div>✅ Correct: <span class="correct-highlight">${correctLetter}. ${correctAns}</span></div>
                <div>❌ Your choice: <span class="${!isCorrect && userChoice !== null ? 'student-answer-wrong' : ''}">${userLetter}. ${userAnsText}</span></div>
                <div class="explanation">📘 <strong>Explanation:</strong> ${q.explanation}</div>
            </div>`;
        }
        document.getElementById('reviewList').innerHTML = reviewHtml;
        quizActive = false;
        quizPanelDiv.style.display = 'none';
        resultPanelDiv.style.display = 'block';
    }
    
    function fullRestart() {
        studentSection.style.display = 'block';
        welcomeBarDiv.style.display = 'none';
        quizPanelDiv.style.display = 'none';
        resultPanelDiv.style.display = 'none';
        document.getElementById('fullName').value = '';
        document.getElementById('classGrade').value = '';
        document.getElementById('schoolName').value = '';
        document.getElementById('studentId').value = '';
        quizActive = false;
    }
    
    // Event listeners
    startQuizBtn.addEventListener('click', () => {
        const name = document.getElementById('fullName').value.trim();
        const cls = document.getElementById('classGrade').value.trim();
        const school = document.getElementById('schoolName').value.trim();
        if (!name || !cls || !school) {
            alert("❌ Please fill in Full Name, Class/Grade, and School Name before starting.");
            return;
        }
        const todayDate = new Date().toISOString().slice(0,10);
        document.getElementById('dateField').value = todayDate;
        studentData = { name, class: cls, school, date: todayDate, id: document.getElementById('studentId').value.trim() };
        showQuizInterface();
    });
    
    nextBtn.addEventListener('click', () => {
        if (!quizActive) return;
        if (studentAnswers[currentIndex] === null) {
            alert("⚠️ Please select an answer before moving to the next question.");
            return;
        }
        if (currentIndex < 99) { currentIndex++; renderQuestion(); }
        else alert("You are at the last question. Press 'Submit Quiz' to finish.");
    });
    
    prevBtn.addEventListener('click', () => {
        if (!quizActive) return;
        if (currentIndex > 0) { currentIndex--; renderQuestion(); }
    });
    
    submitQuizBtn.addEventListener('click', () => {
        if (!quizActive) return;
        const anyNull = studentAnswers.some(ans => ans === null);
        if (anyNull) alert("❗ You have unanswered questions. Please answer all 100 questions before submitting.");
        else computeAndShowResult();
    });
    
    restartBarBtn.addEventListener('click', fullRestart);
    restartResultBtn.addEventListener('click', fullRestart);
    downloadBtn.addEventListener('click', () => { window.print(); });
    
    // BONUS: Disable copy, screenshot, minimize alert
    document.addEventListener('copy', (e) => { e.preventDefault(); alert("📚 Copying is disabled to maintain academic integrity."); return false; });
    document.addEventListener('keydown', (e) => { if (e.key === 'PrintScreen') { e.preventDefault(); alert("Screenshot capture is not allowed."); } });
    document.addEventListener('visibilitychange', () => { if (document.hidden) alert("⚠️ Minimizing or switching tabs is not allowed during the test. Stay focused!"); });
    document.getElementById('dateField').value = new Date().toISOString().slice(0,10);
</script>
</body>
</html>
