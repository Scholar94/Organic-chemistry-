        { text: "The compound CH₃CH₂NH₂ belongs to which class?", options: ["Aldehyde", "Ketone", "Amine", "Ester"], correct: 2, explanation: "Primary amine (ethylamine)." },
        { text: "What type of bond joins two amino acids in a protein?", options: ["Ester bond", "Glycosidic bond", "Peptide bond", "Hydrogen bond"], correct: 2, explanation: "Peptide bond (-CO-NH-) links amino acids." },
