            margin: 0;
            font-size: 1.9rem;
            letter-spacing: -0.5px;
        }
        .student-welcome {
            background: #fef7e0;
            padding: 0.8rem 2rem;
            font-weight: bold;
            border-bottom: 1px solid #ddd6b0;
            color: #2c4b3a;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        /* Form panel */
        .student-form-panel {
            padding: 2rem;
            background: #fffaf0;
            border-bottom: 3px solid #ffb347;
        }
        .form-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1.2rem;
            margin-bottom: 1.5rem;
        }
        .form-group {
            flex: 1 1 200px;
        }
        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.3rem;
            color: #2c5a44;
        }
