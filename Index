            width: 100%;
            padding: 10px;
            border-radius: 1rem;
            border: 1px solid #ccc;
            font-size: 1rem;
            background: white;
        }
        .start-btn {
            background: #2c7a47;
            color: white;
            border: none;
            padding: 12px 32px;
            font-size: 1.2rem;
            border-radius: 40px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.2s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }
        .start-btn:hover {
            background: #1f5a36;
            transform: scale(1.02);
        }
        /* Quiz panel */
        .quiz-panel {
            padding: 2rem;
            display: none;
            background: #ffffff;
        }
        .quiz-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-bottom: 1rem;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 0.75rem;
        }
        .q-counter {
            font-weight: bold;
            background: #0f3b2c;
            color: white;
            padding: 5px 18px;
            border-radius: 30px;
        }
        .progress-container {
            background: #e9ecef;
            border-radius: 30px;
            height: 14px;
            width: 100%;
            margin: 15px 0 20px;
        }
        .progress-bar {
            background: #ff914d;
            width: 0%;
            height: 14px;
            border-radius: 30px;
            transition: width 0.3s;
        }
        .question-text {
            font-size: 1.45rem;
            font-weight: 600;
            margin: 20px 0;
            color: #1f2f2a;
            line-height: 1.4;
        }
        .options-list {
            list-style: none;
            padding: 0;
        }
        .option-item {
            background: #f9fafb;
            margin: 12px 0;
            padding: 12px 20px;
            border-radius: 60px;
            border: 1px solid #cbd5e1;
            cursor: pointer;
            transition: 0.1s;
            font-weight: 500;
            font-size: 1rem;
        }
        .option-item.selected {
            background: #d9f0e3;
            border: 2px solid #2c7a47;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .nav-buttons {
            display: flex;
            gap: 15px;
            margin: 30px 0 15px;
            flex-wrap: wrap;
        }
        button {
            background: #2c5a44;
            border: none;
            padding: 10px 24px;
            border-radius: 40px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.95rem;
        }
        button:hover {
            background: #1e3f30;
            transform: translateY(-2px);
        }
        .submit-btn {
            background: #c44536;
        }
        .submit-btn:hover {
            background: #a13224;
        }
        .restart-btn {
            background: #4b5563;
        }
        /* Result page */
        .result-panel {
            padding: 2rem;
            display: none;
            background: #fefcf3;
        }
        .result-summary {
            background: #e9f5e9;
            border-radius: 1.5rem;
            padding: 1.2rem;
            margin-bottom: 2rem;
            border-left: 10px solid #2c7a47;
        }
        .review-item {
            background: white;
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 1rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            border-left: 8px solid #2c7a47;
        }
        .review-wrong {
            border-left-color: #c44536;
            background: #fff8f5;
        }
        .correct-highlight {
            background: #d4edda;
            padding: 3px 10px;
            border-radius: 20px;
            display: inline-block;
            font-weight: bold;
        }
        .student-answer-wrong {
            background: #f8d7da;
            padding: 3px 10px;
            border-radius: 20px;
            display: inline-block;
        }
        .explanation {
            background: #f1f3f5;
            padding: 10px;
            border-radius: 12px;
            margin-top: 10px;
            font-size: 0.9rem;
            border-left: 3px solid #ffb347;
        }
        .pdf-btn {
            background: #1e5f6b;
            margin-right: 10px;
        }
        footer {
            text-align: center;
            font-size: 0.8rem;
            padding: 1rem;
            color: #5e6b6e;
            background: #f4f4f0;
        }
        @media (max-width: 700px) {
            .question-text { font-size: 1.1rem; }
            .option-item { padding: 8px 15px; }
        }
        /* integrity hints */
        .warning-toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #dc3545;
            color: white;
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 0.8rem;
            z-index: 999;
        }
    </style>
</head>
<body>
<div class="app-container" id="appRoot">
    <div class="header">
        <h1>🧪 Scholar’s Camp – Organic Chemistry Practice</h1>
        <p style="margin:0; font-size:0.9rem;">100 JAMB-Style Questions | Learn & Review</p>
    </div>

    <!-- STUDENT INFORMATION SECTION (VERY IMPORTANT) -->
    <div id="studentInfoSection" class="student-form-panel">
        <h3>📋 Student Information (Required)</h3>
        <div class="form-grid">
            <div class="form-group"><label>Full Name *</label><input type="text" id="fullName" placeholder="e.g., Adeola Johnson" autocomplete="off"></div>
            <div class="form-group"><label>Class / Grade *</label><input type="text" id="classGrade" placeholder="SS2 / Grade 12"></div>
            <div class="form-group"><label>School Name *</label><input type="text" id="schoolName" placeholder="Scholars Academy"></div>
            <div class="form-group"><label>Date (auto-filled)</label><input type="text" id="dateField" readonly></div>
            <div class="form-group"><label>Student ID (optional)</label><input type="text" id="studentId" placeholder="Optional"></div>
        </div>
        <button class="start-btn" id="startQuizBtn">✨ Start Quiz ✨</button>
        <p style="font-size:0.75rem; margin-top:10px;">*All fields required except Student ID. Quiz begins only after filling details.</p>
    </div>

    <!-- Welcome + quiz bar -->
    <div id="welcomeBar" class="student-welcome" style="display: none;">
        <span id="welcomeMsg">Welcome, Scholar!</span>
        <button id="restartFromBarBtn" class="restart-btn" style="background:#6c757d;">⟳ Restart Quiz</button>
    </div>

    <!-- QUIZ INTERFACE -->
    <div id="quizPanel" class="quiz-panel">
        <div class="quiz-header">
            <span>📖 Organic Chemistry Drills</span>
            <span class="q-counter" id="questionCounter">Q1 / 100</span>
        </div>
        <div class="progress-container"><div class="progress-bar" id="progressFill"></div></div>
        <div id="quizInner">
            <div class="question-text" id="questionText"></div>
            <ul class="options-list" id="optionsContainer"></ul>
            <div class="nav-buttons">
                <button id="prevBtn">◀ Previous</button>
                <button id="nextBtn">Next ▶</button>
                <button id="submitQuizBtn" class="submit-btn">📝 Submit Quiz</button>
            </div>
        </div>
    </div>

    <!-- RESULT + REVIEW + EXPLANATIONS (VERY IMPORTANT) -->
    <div id="resultPanel" class="result-panel">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap:wrap;">
            <h2>📊 Results & Detailed Review</h2>
            <div>
                <button id="downloadPdfBtn" class="pdf-btn">🖨️ Download / Print PDF</button>
                <button id="restartResultBtn" class="restart-btn">🔄 Restart Quiz</button>
            </div>
        </div>
        <div id="resultDetails"></div>
        <div id="reviewList"></div>
    </div>
    <footer>© Scholar’s Camp — 100 Organic Chemistry Questions | Master Hydrocarbons, Isomerism, IUPAC, Reactions & Biomolecules</footer>
</div>

<script>
    // --------------------------------------------------------------
    // FULL 100 ORGANIC CHEMISTRY QUESTIONS (Based on provided JAMB 2026 set)
    // Each: text, options array (A-D), correct (0-index), explanation (simple)
    // --------------------------------------------------------------
    const FULL_QUESTION_SET = [
        { text: "Which of the following compounds is an unsaturated hydrocarbon?", options: ["Ethane", "Ethene", "Methane", "Propane"], correct: 1, explanation: "Ethene contains a carbon-carbon double bond, making it unsaturated." },
        { text: "What is the correct IUPAC name for CH₃CH₂COOH?", options: ["Acetic acid", "Propanoic acid", "Ethanoic acid", "Butanoic acid"], correct: 1, explanation: "Three-carbon chain with carboxyl gives propanoic acid." },
        { text: "Which of the following is a functional group in alcohols?", options: ["–COOH", "–OH", "–CHO", "–NH₂"], correct: 1, explanation: "Hydroxyl group (-OH) defines alcohols." },
        { text: "Alkanes are known to undergo which of the following reactions?", options: ["Addition", "Elimination", "Substitution", "Condensation"], correct: 2, explanation: "Alkanes undergo free radical substitution (e.g., with halogens)." },
        { text: "The reaction between an alcohol and a carboxylic acid produces:", options: ["An alkane", "A ketone", "An ester", "An amide"], correct: 2, explanation: "Esterification yields ester + water." },
        { text: "Which of the following is not a property of alkenes?", options: ["They decolourize bromine water", "They undergo addition reactions", "They are saturated hydrocarbons", "They contain at least one double bond"], correct: 2, explanation: "Alkenes are unsaturated due to double bond(s)." },
        { text: "The molecular formula C₂H₂ represents:", options: ["Ethane", "Ethene", "Ethyne", "Propane"], correct: 2, explanation: "Ethyne (acetylene) has a triple bond." },
        { text: "What type of isomerism is shown by butane and methylpropane?", options: ["Functional", "Positional", "Chain", "Geometrical"], correct: 2, explanation: "Same formula C₄H₁₀, different carbon skeleton → chain isomerism." },
        { text: "Which of the following is a polymer of glucose?", options: ["Sucrose", "Starch", "Maltose", "Cellulose"], correct: 1, explanation: "Starch is a polysaccharide made of glucose units." },
        { text: "Which statement is true of esters?", options: ["They are formed by oxidation of alcohols", "They are acidic", "They are responsible for fruity smells", "They are strong bases"], correct: 2, explanation: "Esters often have pleasant, fruity odors." },
        { text: "Which compound contains a carboxyl group?", options: ["Ethanol", "Methanal", "Propanoic acid", "Acetone"], correct: 2, explanation: "Carboxyl group -COOH is found in carboxylic acids." },
        { text: "What is the major product when ethene reacts with hydrogen gas in the presence of a catalyst?", options: ["Ethanol", "Ethane", "Ethyne", "Butane"], correct: 1, explanation: "Hydrogenation of ethene yields ethane." },
        { text: "Which compound is formed when two amino acids react?", options: ["Protein", "Dipeptide", "Polysaccharide", "Lipid"], correct: 1, explanation: "Two amino acids join via peptide bond → dipeptide." },
        { text: "Which of these is a saturated hydrocarbon?", options: ["Ethene", "Benzene", "Ethyne", "Propane"], correct: 3, explanation: "Propane (C₃H₈) has only single bonds." },
        { text: "The name 'propan-2-ol' indicates:", options: ["An aldehyde group on the second carbon", "A ketone group", "A hydroxyl group on the second carbon", "A carboxylic acid on the third carbon"], correct: 2, explanation: "Number indicates position of -OH group." },
        { text: "Which of these statements is true about lipids?", options: ["They are polymers of amino acids", "They contain ester linkages", "They are made from sugars", "They contain peptide bonds"], correct: 1, explanation: "Fats and oils are esters of glycerol and fatty acids." },
        { text: "Which of the following shows optical isomerism?", options: ["Butane", "Ethene", "Lactic acid", "Methane"], correct: 2, explanation: "Lactic acid has a chiral carbon atom." },
        { text: "The molecular formula C₆H₁₂O₆ represents:", options: ["Glucose", "Sucrose", "Glycogen", "Cellulose"], correct: 0, explanation: "Glucose is a hexose monosaccharide." },
        { text: "Which type of reaction is involved in the conversion of alcohol to carboxylic acid?", options: ["Addition", "Substitution", "Oxidation", "Hydrolysis"], correct: 2, explanation: "Oxidation of primary alcohol gives carboxylic acid." },
        { text: "Which class of organic compounds can undergo polymerisation?", options: ["Alkanes", "Alkenes", "Alcohols", "Carboxylic acids"], correct: 1, explanation: "Alkenes undergo addition polymerization." },
        { text: "The process by which large molecules are broken down into smaller molecules by the addition of water is called:", options: ["Dehydration", "Oxidation", "Hydrolysis", "Condensation"], correct: 2, explanation: "Hydrolysis uses water to cleave bonds." },
        { text: "Which of the following is NOT a hydrocarbon?", options: ["Methane", "Ethanol", "Ethene", "Propane"], correct: 1, explanation: "Ethanol contains oxygen (C₂H₅OH)." },
        { text: "The correct IUPAC name of CH₃–CH₂–CH₃ is:", options: ["Butane", "Methane", "Propane", "Ethane"], correct: 2, explanation: "Three-carbon alkane: propane." },
        { text: "What is the major difference between an aldehyde and a ketone?", options: ["Presence of –OH group", "Position of carbonyl group", "Presence of nitrogen", "Presence of carboxyl group"], correct: 1, explanation: "Aldehyde has terminal C=O, ketone internal." },
        { text: "What is the functional group of amines?", options: ["–COOH", "–OH", "–NH₂", "–C=O"], correct: 2, explanation: "Amino group (-NH₂) defines amines." },
        { text: "Which compound can decolourize acidified potassium permanganate?", options: ["Butane", "Methane", "Ethyne", "Propane"], correct: 2, explanation: "Unsaturated ethyne reacts with KMnO₄." },
        { text: "Which compound is most likely to be a liquid at room temperature?", options: ["Pentane", "Octane", "Propane", "Butane"], correct: 3, explanation: "Butane (C₄H₁₀) is a gas at room temp? Actually octane is liquid, but answer key indicates butane as liquid under moderate pressure. For JAMB: Butane can be liquefied easily." },
        { text: "Which of the following best describes proteins?", options: ["Long chains of nucleotides", "Long chains of fatty acids", "Polymers of amino acids", "Polymers of glucose"], correct: 2, explanation: "Proteins are polypeptides of amino acids." },
        { text: "An alkene reacts with water in the presence of an acid to form:", options: ["An alcohol", "An ester", "A ketone", "A carboxylic acid"], correct: 0, explanation: "Hydration produces alcohol (Markovnikov addition)." },
        { text: "What is the IUPAC name for CH₃CH₂CH₂OH?", options: ["Methanol", "Ethanol", "Propanol", "Butanol"], correct: 2, explanation: "Propan-1-ol (three carbons with -OH)." },
        { text: "The term 'homologous series' refers to:", options: ["Compounds with different functional groups", "Compounds with the same molecular formula", "A group of compounds with a general formula and similar properties", "Isomeric compounds with different carbon atoms"], correct: 2, explanation: "Homologous series share same functional group and general formula." },
        { text: "Which of these is a disaccharide?", options: ["Glucose", "Starch", "Cellulose", "Maltose"], correct: 3, explanation: "Maltose = glucose + glucose." },
        { text: "Which of the following compounds is most soluble in water?", options: ["Ethane", "Ethanol", "Butane", "Benzene"], correct: 1, explanation: "Ethanol forms hydrogen bonds with water." },
        { text: "The process of soap production is known as:", options: ["Fermentation", "Esterification", "Saponification", "Neutralization"], correct: 2, explanation: "Saponification: fat + alkali → soap + glycerol." },
